    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.6.2",
    "codemirror": "^6.0.1",
    "dompurify": "^3.2.5",
    "element-plus": "^2.4.3",
    "marked": "^15.0.11",
    "pinia": "^2.1.7",
    "uuid": "^11.1.0",
    "vue": "^3.3.9",
    "vue-codemirror": "^6.1.1",
    "vue-router": "^4.2.5",
    "vue3-ts-jsoneditor": "^3.0.3"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.1",
