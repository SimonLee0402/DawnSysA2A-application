{
  "name": "a2a-workflow-platform-root",
  "version": "1.0.0",
  "description": "Agent-to-Agent 工作流平台",
  "private": true,
  "scripts": {
    "frontend:dev": "cd frontend_src && npm run dev",
    "frontend:build": "cd frontend_src && npm run build",
    "frontend:deploy": "cd frontend_src && npm run deploy",
    "frontend:watch": "cd frontend_src && npm run build:watch",
    "backend:run": "python manage.py runserver",
    "backend:migrate": "python manage.py migrate",
    "backend:makemigrations": "python manage.py makemigrations",
    "backend:collectstatic": "python manage.py collectstatic --noinput",
    "setup": "cd frontend_src && npm install",
    "dev": "concurrently \"npm run backend:run\" \"npm run frontend:dev\"",
    "build": "npm run frontend:build && npm run backend:collectstatic",
    "start": "python manage.py runserver"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
} 